generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VOLUNTEER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role     @default(VOLUNTEER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Topic {
  id          String    @id @default(cuid())
  title       String
  description String?
  sortOrder   Int       @default(0)
  taught      Boolean   @default(false)
  taughtAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contents    Content[]
  quizzes     Quiz[]
}

model Content {
  id        String   @id @default(cuid())
  topicId   String
  title     String
  body      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Student {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stars     Star[]
}

model Quiz {
  id        String   @id @default(cuid())
  topicId   String
  question  String
  options   String[] // array of options
  answer    Int      // index of correct option
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Star {
  id        String   @id @default(cuid())
  studentId String
  topicId   String
  points    Int      @default(0)
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, topicId])
  @@index([studentId])
}

model Quote {
  id          String @id @default(cuid())
  quote       String // the quote text (Amharic or English)
  reference   String // e.g. "ዮሐንስ 3:16"
  category    String // e.g. "hope", "happiness", "resilience"
  createdAt   DateTime @default(now())
}
